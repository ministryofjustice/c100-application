<% title t('.page_title', name: @form_object.record.full_name) %>
<% step_header %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= govuk_error_summary %>

    <h1 class="govuk-heading-xl"><%= t('.heading', name: @form_object.record.full_name) %></h1>

    <p class="govuk-body govuk-!-font-weight-bold"><%= t('.lead_text', name: @form_object.record.full_name) %></p>

    <p class="govuk-hint"><%= t '.hint' %></p>

    <%= step_form @form_object, builder: GOVUKDesignSystemFormBuilder::FormBuilder do |f| %>
      <%= f.govuk_collection_radio_buttons :are_contact_details_private, GenericYesNo.values, :value, nil, legend: nil %>

      <%= f.continue_button %>
    <% end %>
  </div>
</div>
