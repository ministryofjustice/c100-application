<% title t('.page_title', name: @form_object.record.full_name) %>
<% step_header %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= govuk_error_summary %>

    <h1 class="govuk-heading-xl"><%= t('.heading', name: @form_object.record.full_name) %></h1>

    <%= step_form @form_object, builder: GOVUKDesignSystemFormBuilder::FormBuilder do |f| %>
      <%= f.govuk_collection_radio_buttons :are_identity_details_private, GenericYesNo.values, :value, nil,
                                           legend: { tag: 'span', size: 's' , text: t('.legend', name: @form_object.record.full_name) }, hint: { text: t('.hint') } %>

      <%= f.continue_button %>
    <% end %>
  </div>
</div>
